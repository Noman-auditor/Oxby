# ══════════════════════════════════════════════════
#  VAULT — Environment Configuration
# ══════════════════════════════════════════════════

# Bitcoin Network: mainnet | testnet
BTC_NETWORK=mainnet

# Server
PORT=3001
NODE_ENV=production

# CORS — your frontend URL
FRONTEND_URL=http://localhost:3000

# API Authentication Key (generate a strong random string)
# Used to protect all /api/* endpoints
API_SECRET_KEY=change_this_to_a_long_random_secret_key_min_32_chars

# ── WALLET CREDENTIALS (never commit these) ──────
# Add your WIF private key OR mnemonic here
# The app will auto-load the wallet on startup

# Option A: WIF Private Key (starts with K, L, or 5 on mainnet)
# WALLET_WIF=

# Option B: 12 or 24-word mnemonic seed phrase
# WALLET_MNEMONIC=word1 word2 word3 ... word12

# BIP44 derivation (only used with mnemonic)
WALLET_ACCOUNT_INDEX=0
WALLET_ADDRESS_INDEX=0
