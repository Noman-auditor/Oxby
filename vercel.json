{
  "version": 2,
  "name": "vault-btc",
  "buildCommand": "npm install",
  "outputDirectory": "public",
  "rewrites": [
    { "source": "/api/health",        "destination": "/backend/api/health.js" },
    { "source": "/api/wallet/(.*)",   "destination": "/backend/api/wallet.js" },
    { "source": "/api/tx/(.*)",       "destination": "/backend/api/tx.js" },
    { "source": "/api/market",        "destination": "/backend/api/market.js" },
    { "source": "/(.*)",              "destination": "/public/$1" }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin",  "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET,POST,OPTIONS" },
        { "key": "Access-Control-Allow-Headers", "value": "Content-Type, X-API-Key" },
        { "key": "X-Content-Type-Options",       "value": "nosniff" },
        { "key": "X-Frame-Options",              "value": "DENY" }
      ]
    }
  ],
  "env": {
    "BTC_NETWORK": "mainnet",
    "NODE_ENV": "production"
  },
  "functions": {
    "backend/api/**/*.js": { "maxDuration": 30, "memory": 512 }
  }
}
